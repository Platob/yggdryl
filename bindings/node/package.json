{
  "name": "yggdryl",
  "version": "0.1.1",
  "description": "yggdryl — a Rust-core library, exposed to Node.js",
  "main": "yggdryl.js",
  "types": "yggdryl.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Platob/yggdryl.git"
  },
  "homepage": "https://platob.github.io/yggdryl/",
  "keywords": [
    "rust",
    "napi",
    "node",
    "ffi",
    "yggdryl"
  ],
  "napi": {
    "name": "yggdryl",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --test",
    "bench": "node benchmark/compression.bench.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "files": [
    "yggdryl.js",
    "yggdryl.d.ts",
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
