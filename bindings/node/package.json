{
  "name": "yggdryl",
  "version": "0.1.1",
  "description": "yggdryl \u2014 a Rust-core URI/URL library, exposed to Node.js",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Platob/yggdryl.git"
  },
  "homepage": "https://github.com/Platob/yggdryl",
  "keywords": [
    "uri",
    "url",
    "parser",
    "rust",
    "napi",
    "yggdryl"
  ],
  "napi": {
    "name": "yggdryl",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --test",
    "bench": "node bench/dtype.bench.js && node bench/field.bench.js && node bench/scalar.bench.js && node bench/serie.bench.js && node bench/factory.bench.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
